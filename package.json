{
  "name": "workermate",
  "private": true,
  "packageManager": "npm@10.9.2",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "dotenv": "^17.4.2",
    "prettier": "^3.7.4",
    "turbo": "^2.10.3",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bullmq": "^5.79.2",
    "class-validator": "^0.15.1",
    "ioredis": "^5.11.1",
    "pg": "^8.22.0",
    "prisma": "^6.19.3"
  }
