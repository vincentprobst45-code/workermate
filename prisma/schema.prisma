generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model Tenant {
  id        String    @id @default(uuid())
  name      String
  createdAt DateTime  @default(now())

  addressId String?
  address   Address?  @relation(fields: [addressId], references: [id], onDelete: Cascade)

  memberships Membership[]
  customers   Customer[]
  projects    Project[]
  invoices    Invoice[]
}

model User {
  id         String       @id @default(uuid())
  email      String       @unique
  password   String
  firstname  String?
  lastname   String?
  activeTenantId String?

  addressId String?
  address   Address?  @relation(fields: [addressId], references: [id], onDelete: Cascade)

  createdAt  DateTime     @default(now())

  memberships Membership[]
}

model Membership {
  userId   String
  tenantId String
  role     TenantRole
  joinedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@id([userId, tenantId])
}

model Address {
  id String @id @default(cuid())

  // Adresse
  street1 String
  street2 String?

  postalCode String
  city       String
  region     String?
  countryCode String @default("FR")

  // Coordonnées GPS (optionnel)
  latitude  Decimal? @db.Decimal(10, 7)
  longitude Decimal? @db.Decimal(10, 7)

  // Informations complémentaires
  accessCode String?
  floor      String?
  apartment  String?
  note       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  customers Customer[]
  projects Project[]
  tenants Tenant[]
  users User[]
}

model Customer {
  id        String   @id @default(uuid())

  // Relation
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Identité
  firstName String?
  lastName  String?
  company   String?

  // Contact
  email     String?
  phone     String?
  mobile    String?


  // Addresse de facturation
  addressId String?
  address   Address?  @relation(fields: [addressId], references: [id], onDelete: Cascade)


  // Professionnels
  siret     String?
  vatNumber String?

  // Divers
  notes     String?

  // Relations
  projects    Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  @@index([tenantId])
  @@index([lastName])
  @@index([company])
}

model Project {
  id          String   @id @default(cuid())

  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  customerId    String
  customer      Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)

  addressId   String?
  address     Address?  @relation(fields: [addressId], references: [id])

  reference   String   @unique

  title       String
  description String?

  status      ProjectStatus @default(DRAFT)

  startDate   DateTime?
  endDate     DateTime?

  estimatedDuration Int?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  archivedAt DateTime?

  items ProjectItem[]

  documents Document[]

  @@index([tenantId])
  @@index([customerId])
}

model ProjectItem {

  id String @id @default(cuid())

  projectId String
  project Project @relation(fields:[projectId], references:[id], onDelete:Cascade)

  type ProjectItemType

  position Int

  title String

  description String?

  quantity Decimal @db.Decimal(10,2) @default(1)

  unit String?

  unitPrice Decimal @db.Decimal(10,2)

  vatRate Decimal @db.Decimal(4,2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model Document {

  id String @id @default(cuid())

  projectId String
  project Project @relation(fields:[projectId], references:[id], onDelete:Cascade)

  type DocumentType

  reference String @unique

  status DocumentStatus

  issuedAt DateTime?

  dueAt DateTime?

  notes String?

  createdAt DateTime @default(now())

  items DocumentItem[]
}

model DocumentItem {

  id String @id @default(cuid())

  documentId String
  document Document @relation(fields:[documentId], references:[id], onDelete:Cascade)

  position Int

  type ProjectItemType

  title String

  description String?

  quantity Decimal @db.Decimal(10,2)

  unit String?

  unitPrice Decimal @db.Decimal(10,2)

  vatRate Decimal @db.Decimal(4,2)
}

model Invoice {
  id          String   @id @default(uuid())
  number      String
  amount      Float
  description String?
  customerId  String?

  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TenantRole {
  OWNER
  ADMIN
  MEMBER
}

enum ProjectStatus {
  DRAFT
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ProjectItemType {
  LABOR
  MATERIAL
  EQUIPMENT
  TRAVEL
  SERVICE
  OTHER

}

enum DocumentType {
  ESTIMATE
  INVOICE
  OTHER
}

enum DocumentStatus {
  NOTREADY
  READY
  SENT
  VALIDATED
}